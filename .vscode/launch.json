{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug proactive (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/cpp/build/proactive",
      "args": [],
      "cwd": "${workspaceFolder}/cpp",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}

